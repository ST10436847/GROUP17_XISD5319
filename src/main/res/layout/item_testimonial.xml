<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#2C1810">

            <!-- Quote Icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/quote_symbol"
                android:textColor="#D4AF37"
                android:textSize="40sp"
                android:textStyle="bold"
                android:lineSpacingExtra="0dp" />

            <!-- Star Rating -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/five_stars"
                    android:textColor="#D4AF37"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Testimonial Text -->
            <TextView
                android:id="@+id/tvTestimonialText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/testimonial_placeholder"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:lineSpacingExtra="6dp"
                android:gravity="center"
                android:minHeight="100dp"
                android:maxLines="8"
                android:ellipsize="end"
                android:scrollHorizontally="false"
                android:breakStrategy="simple"
                android:justificationMode="inter_word" />

            <!-- Divider -->
            <View
                android:layout_width="50dp"
                android:layout_height="2dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:background="#D4AF37" />

            <!-- Customer Name -->
            <TextView
                android:id="@+id/tvTestimonialName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/customer_name_placeholder"
                android:textColor="#D4AF37"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="2" />

            <!-- Customer Title -->
            <TextView
                android:id="@+id/tvCustomerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:text="@string/verified_buyer"
                android:textColor="#999999"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>